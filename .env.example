# BfArM Referenzdaten — Update-Konfiguration
# Kopiere diese Datei nach .env und passe die Werte bei Bedarf an.

# ─── Pfade (relativ zum Projektroot) ─────────────────────
DB_PATH=db/bfarm.db
DB_GZ_PATH=db/bfarm.db.gz
DATA_DIR=data
CSV_PATH=data/lieferengpass.csv
IMPORT_SCRIPT=src/import_bfarm.py
README_PATH=README.md

# ─── URLs ─────────────────────────────────────────────────
LIEFERENGPASS_CSV_URL=https://anwendungen.pharmnet-bund.de/lieferengpassmeldungen/public/csv

# ─── Git ──────────────────────────────────────────────────
# Remote-Name für Push (muss konfiguriert sein via `git remote add`)
# "all" pusht parallel auf GitHub + Codeberg (siehe README)
GIT_REMOTE=all
GIT_BRANCH=main

# ─── Pattern für DSV-Verzeichnisse ────────────────────────
# Glob-Pattern für Auto-Detect des neuesten Datenverzeichnisses
DSV_PATTERN=*-REFERENCE

# ─── Optional: Download-Timeout in Sekunden ───────────────
DOWNLOAD_TIMEOUT=60
